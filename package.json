{
  "name": "morning-signal-v3",
  "version": "3.0.0",
  "private": true,
  "description": "AI-powered briefing and newsletter platform",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": ["shared", "server", "client"],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=shared && npm run build --workspace=server && npm run build --workspace=client",
    "start": "npm run start --workspace=server",
    "test": "npm run test --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
