<mjml>
  <mj-head>
    <mj-attributes>
      <mj-all font-family="{{fontFamily}}" />
      <mj-text font-size="16px" line-height="1.6" color="{{textColor}}" />
      <mj-section padding="0 20px" />
    </mj-attributes>
    <mj-style>
      a { color: {{accentColor}}; text-decoration: underline; }
    </mj-style>
  </mj-head>
  <mj-body background-color="{{backgroundColor}}">
    <!-- Header -->
    <mj-section background-color="{{headerColor}}" padding="20px 30px">
      <mj-column>
        <mj-text color="#ffffff" font-size="28px" font-weight="bold" align="center">
          {{newsletterName}}
        </mj-text>
        <mj-text color="#e0e0e0" font-size="14px" align="center" padding-top="4px">
          Edition #{{editionNumber}} — {{editionDate}}
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Lead Story -->
    <mj-section background-color="{{cardColor}}" padding="24px 30px">
      <mj-column>
        <mj-text font-size="12px" color="{{accentColor}}" font-weight="bold" text-transform="uppercase" letter-spacing="2px">
          {{leadSectionName}}
        </mj-text>
        <mj-text font-size="22px" font-weight="bold" padding-top="8px">
          {{leadStoryHeadline}}
        </mj-text>
        <mj-text padding-top="12px">
          {{leadStoryContent}}
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section padding="0"><mj-column><mj-divider border-color="#e0e0e0" border-width="1px" /></mj-column></mj-section>

    <!-- Briefings -->
    <mj-section background-color="{{cardColor}}" padding="24px 30px">
      <mj-column>
        <mj-text font-size="12px" color="{{accentColor}}" font-weight="bold" text-transform="uppercase" letter-spacing="2px">
          {{briefingSectionName}}
        </mj-text>
        {{quickHitsContent}}
      </mj-column>
    </mj-section>

    <mj-section padding="0"><mj-column><mj-divider border-color="#e0e0e0" border-width="1px" /></mj-column></mj-section>

    <!-- Watch List -->
    <mj-section background-color="{{cardColor}}" padding="24px 30px">
      <mj-column>
        <mj-text font-size="12px" color="{{accentColor}}" font-weight="bold" text-transform="uppercase" letter-spacing="2px">
          {{watchSectionName}}
        </mj-text>
        {{watchListContent}}
      </mj-column>
    </mj-section>

    <!-- Footer -->
    <mj-section background-color="{{footerColor}}" padding="20px 30px">
      <mj-column>
        <mj-text color="#a0a0b0" font-size="12px" align="center">
          You're receiving this because you subscribed to {{newsletterName}}.
        </mj-text>
        <mj-text color="#a0a0b0" font-size="12px" align="center" padding-top="4px">
          <a href="{{unsubscribeUrl}}" style="color: #a0a0b0;">Unsubscribe</a>
        </mj-text>
        <mj-text color="#a0a0b0" font-size="11px" align="center" padding-top="8px">
          {{physicalAddress}}
        </mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
